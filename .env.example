# MiniMax API（必填）
# 复制此文件为 .env 并填入你的 key

MINIMAX_API_KEY=sk-api-你的key

# 可选：模型名，默认 MiniMax-M2.5（官方 Anthropic 兼容接口支持：MiniMax-M2.5 / MiniMax-M2.5-highspeed / MiniMax-M2.1 / MiniMax-M2）
# MINIMAX_MODEL=MiniMax-M2.5

# 可选：服务端口，默认 3000
# PORT=3000

# ══════════════════════════════════════════════════════════════
# 联网搜索 API（二选一，配置后 AI 分析将基于真实搜索结果）
# ══════════════════════════════════════════════════════════════

# 方式一：Serper.dev（推荐，注册即送 2500 次免费搜索）
# 注册地址：https://serper.dev
SERPER_API_KEY=你的serper_key

# 方式二：SerpAPI
# 注册地址：https://serpapi.com
# SERPAPI_KEY=你的serpapi_key

# 说明：
# - 两个都配置时优先使用 Serper
# - 都不配置时，AI 仍可分析但 aiFindings 字段不基于联网搜索
# - 建议至少配置一个，否则"AI 联网研究"将无法获取真实搜索数据
