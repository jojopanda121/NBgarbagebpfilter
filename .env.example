# ══════════════════════════════════════════════════════════════
# GarbageBPFilter v2.0 配置
# 复制此文件为 .env 并填入你的 key
# ══════════════════════════════════════════════════════════════

# MiniMax API（必填）
MINIMAX_API_KEY=sk-api-你的key

# 可选：模型名，默认 MiniMax-M2.5
# 支持：MiniMax-M2.5 / MiniMax-M2.5-highspeed / MiniMax-M2.1 / MiniMax-M2
# MINIMAX_MODEL=MiniMax-M2.5

# 可选：后端端口，默认 3001
# PORT=3001

# ══════════════════════════════════════════════════════════════
# 联网搜索 API（Serper.dev）
# 注册地址：https://serper.dev（注册即送 2500 次免费搜索）
# 不配置时使用 Mock 模式，AI 仍可分析但无真实搜索验证
# ══════════════════════════════════════════════════════════════
SERPER_API_KEY=你的serper_key
