# ══════════════════════════════════════════════════════════════
# GarbageBPFilter v3.0 配置
# 复制此文件为 .env 并填入你的 key
# ══════════════════════════════════════════════════════════════

# ── MiniMax API（必填）──
MINIMAX_API_KEY=sk-api-你的key

# 可选：模型名，默认 MiniMax-M2.7
# MINIMAX_MODEL=MiniMax-M2.7
# MiniMax 自带联网搜索：优先使用 Coding Plan key；如 MINIMAX_API_KEY 本身就是 coding-plan token，也会作为兼容 fallback 使用
# MINIMAX_CODE_PLAN_KEY=
# MINIMAX_CODING_API_KEY=
# 国内版 Token Plan 使用 minimaxi.com。这里只填根域名，不要带 /anthropic。
# MINIMAX_API_HOST=https://api.minimaxi.com
# MiniMax 图片生成模型
# MINIMAX_IMAGE_MODEL=image-01
# MINIMAX_SEARCH_REGION=global

# ── 后端端口，默认 3001 ──
# PORT=3001

# ── JWT 认证（生产环境必须修改！）──
# 生成强随机密钥：openssl rand -hex 32
# 要求：长度 ≥ 32，不得保留 "请修改" 这类占位文案，否则生产启动会被强制中止
JWT_SECRET=
JWT_EXPIRES_IN=12h

# ── 允许 /api/analyze 匿名访问（仅本地开发/演示！）──
# 仅当 NODE_ENV !== production 且此值为 1 时才生效；生产环境永远禁用。
# ALLOW_ANON_ANALYZE=0

# ── 数据库路径 ──
# DB_PATH=./data/app.db

# ── 免费额度（注册时赠送的次数）──
# DEFAULT_FREE_QUOTA=3

# ══════════════════════════════════════════════════════════════
# 企查查 Agent API（企业追踪数据源）
# 用于自动跟踪已分析企业的后续发展，验证评分预测准确性
# 不配置时追踪功能不可用，不影响核心分析功能
# ══════════════════════════════════════════════════════════════
# QCC_API_KEY=你的企查查agent_api_key

# ══════════════════════════════════════════════════════════════
# 文档提取微服务（Docker Compose 模式下自动配置）
# 不配置时使用本地 Python 子进程（fallback 模式）
# ══════════════════════════════════════════════════════════════
# DOC_SERVICE_URL=http://doc-service:8001

# ══════════════════════════════════════════════════════════════
# 支付网关配置（商业化后配置）
# ══════════════════════════════════════════════════════════════
# WECHAT_PAY_APP_ID=
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_API_KEY=
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=

# ══════════════════════════════════════════════════════════════
# 腾讯云短信配置（验证码服务）
# ══════════════════════════════════════════════════════════════
# TENCENT_SMS_SECRET_ID=你的SecretId
# TENCENT_SMS_SECRET_KEY=你的SecretKey
# TENCENT_SMS_SDK_APP_ID=你的SdkAppId
# TENCENT_SMS_SIGN_NAME=你的短信签名
# TENCENT_SMS_TEMPLATE_ID=你的模板ID
# TENCENT_SMS_REGION=ap-guangzhou

# ══════════════════════════════════════════════════════════════
# 腾讯云 SES 邮件服务（验证码发送）
# 发信域名需在腾讯云 SES 控制台验证通过
# ══════════════════════════════════════════════════════════════
# TENCENT_SES_SECRET_ID=你的SecretId
# TENCENT_SES_SECRET_KEY=你的SecretKey
# TENCENT_SES_FROM_EMAIL=垃圾BP过滤机 <noreply@www.garbagebpfilter.cn>
# TENCENT_SES_REGION=ap-hongkong
# TENCENT_SES_TEMPLATE_ID=你的邮件模板ID（在腾讯云SES控制台创建，模板变量使用 {{code}}）

# ══════════════════════════════════════════════════════════════
# 对象存储（可选，用于 BP 文件和报告持久化）
# ══════════════════════════════════════════════════════════════
# OSS_ENDPOINT=
# OSS_BUCKET=
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=

# ══════════════════════════════════════════════════════════════
# 前端跨域配置（前后端分离部署时必填）
# ══════════════════════════════════════════════════════════════
# REACT_APP_API_URL=https://your-backend-domain.com

# CORS 允许的域名（逗号分隔，生产环境必须配置！不配置则拒绝所有跨域请求）
# ALLOWED_ORIGINS=https://your-frontend-domain.com,https://admin.your-domain.com

# ══════════════════════════════════════════════════════════════
# 管理员账号配置（可选，部署时设置）
# 设置后，系统启动时自动创建或升级管理员账号
# ══════════════════════════════════════════════════════════════
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your_secure_password

# ══════════════════════════════════════════════════════════════
# Multiagent 投研工作台配置（Sprint 1）
# ══════════════════════════════════════════════════════════════

# 创始人姓名加密密钥（64位十六进制，即 32 字节 AES-256 密钥）
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=your_64_hex_chars_here

# PII Hash 盐值（手机号/邮箱 SHA256 hash 时使用）
# 建议随机生成并保密，防止彩虹表攻击
# PII_SALT=your_random_salt_here

# 市场雷达冷启动期：数据量不足时使用公开数据 fallback
# RADAR_USE_PUBLIC_DATA_FALLBACK=true
