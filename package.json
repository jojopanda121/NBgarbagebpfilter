{
  "name": "bp-filter",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "install:all": "cd client && npm install && cd ../server && npm install",
    "build": "cd client && npm install && npm run build",
    "start": "pm2 start ecosystem.config.js --env production",
    "start:dev": "pm2 start ecosystem.config.js --env development",
    "stop": "pm2 stop garbagebpfilter",
    "restart": "pm2 restart garbagebpfilter",
    "logs": "pm2 logs garbagebpfilter",
    "deploy": "npm run build && npm start"
  }
}
